{
  "expo": {
    "name": "VirtusQ",
    "slug": "volleyball-ai-app",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": ["virtusq"],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.orgil.volleyballai",
      "usesAppleSignIn": true,
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "VirtusQ accesses your photo library so you can choose a profile picture and upload volleyball training videos for AI analysis, such as receiving feedback on your technique and performance.",
        "NSPhotoLibraryAddUsageDescription": "VirtusQ allows you to save your profile picture, analyzed videos, or feedback results to your photo library when you choose to export them."
      }
    },
    "android": {
      "package": "com.orgil.volleyballai",
      "versionCode": 4,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c7a173cb-b16d-4960-b486-e78f53c1a299"
      }
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}